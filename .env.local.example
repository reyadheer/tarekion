# ─────────────────────────────────────────────
# Tarekion Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────

# Your WhatsApp number (no + or spaces, e.g. 966501234567)
NEXT_PUBLIC_WHATSAPP_NUMBER=966500000000

# Your phone number (displayed in UI)
NEXT_PUBLIC_PHONE_NUMBER=+966-50-000-0000

# Your email address
NEXT_PUBLIC_EMAIL=info@tarekion.com

# Your live domain (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.tarekion.com

# Google Search Console verification ID (optional)
NEXT_PUBLIC_GSC_ID=YOUR_GOOGLE_SEARCH_CONSOLE_ID
